NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Sign-In (web OAuth Client ID from Google Cloud Console).
# Public-safe: the value ships in client HTML.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Demo account credentials (read-only account)
DEMO_EMAIL=demo@stockmanswallet.com.au
DEMO_PASSWORD=change-me
